# Server
PORT=5000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/fakenews

# ML Service (Python FastAPI)
ML_SERVICE_URL=http://localhost:8000

# ── Search APIs (get these free keys) ────────────────────────────────────
# SerpAPI — 100 free searches/month: https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# NewsAPI — 1000 req/day free: https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# Google Fact Check Tools API — FREE (just needs a Google Cloud API key)
# Enable at: https://console.cloud.google.com/apis → "Fact Check Tools API"
# This is the most important one for accuracy!
GOOGLE_FACT_CHECK_API_KEY=your_google_api_key_here

# ── LLM for enhanced explanations (optional) ─────────────────────────────
# GPT-4o-mini for richer cited explanations
OPENAI_API_KEY=your_openai_key_here
